{
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": true,
    "claude-api@anthropic-agent-skills": true
  },
  "permissions": {
    "read": {
      "deny": [
        "**/__pycache__/**",
        "**/*.py[cod]",
        "**/*.egg-info/**",
        "**/.eggs/**",
        "**/.venv/**",
        "**/venv/**",
        "**/env/**",
        "**/.git/**",
        "**/.streamlit/secrets.toml",
        "**/.env",
        "**/.env.*",
        "**/.idea/**",
        "**/.vscode/**",
        "**/dist/**",
        "**/build/**",
        "**/*.tmp",
        "**/~$*"
      ]
    }
  }
}
